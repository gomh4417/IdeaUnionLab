# Firebase 설정
VITE_FB_API_KEY=your_firebase_api_key_here
VITE_FB_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FB_PROJECT_ID=your_project_id
VITE_FB_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FB_MESSAGING_SENDER_ID=your_sender_id
VITE_FB_API_ID=your_app_id

# OpenAI API 설정
VITE_OPENAI_API_KEY=your_openai_api_key_here

# 사용 방법:
# 1. 이 파일을 .env로 복사하세요
# 2. 실제 API 키 값들로 교체하세요
# 3. .env 파일은 절대 GitHub에 업로드하지 마세요!
